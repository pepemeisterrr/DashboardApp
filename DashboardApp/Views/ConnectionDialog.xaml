<Window x:Class="DashboardApp.Views.ConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройка подключения к PostgreSQL" 
        Height="420" Width="480" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Параметры подключения к базе данных" 
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1">
            <Label Content="Хост:"/>
            <TextBox Text="{Binding Host}" Margin="0,0,0,8"/>

            <Label Content="Порт:"/>
            <TextBox Text="{Binding Port}" Margin="0,0,0,8"/>

            <Label Content="Имя базы данных:"/>
            <TextBox Text="{Binding Database}" Margin="0,0,0,8"/>

            <Label Content="Логин:"/>
            <TextBox Text="{Binding Username}" Margin="0,0,0,8"/>

            <Label Content="Пароль:"/>
            <PasswordBox x:Name="PasswordBox" 
                         PasswordChanged="PasswordBox_PasswordChanged" 
                         Margin="0,0,0,15"/>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="{Binding StatusMessage}" 
                       FontWeight="SemiBold" Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Проверить соединение" 
                        Command="{Binding TestConnectionCommand}"
                        Width="170" Margin="0,0,10,0"/>

                <Button Content="Сохранить" 
                        Command="{Binding SaveCommand}" 
                        Width="100" Margin="0,0,10,0"/>

                <Button Content="Отмена" 
                        Command="{Binding CancelCommand}" 
                        Width="80"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>