<Window x:Class="DashboardApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DashboardApp.ViewModels"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Дашборд аналитики" 
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Меню -->
            <RowDefinition Height="Auto"/>
            <!-- Фильтры -->
            <RowDefinition Height="Auto"/>
            <!-- KPI -->
            <RowDefinition Height="*"/>
            <!-- График -->
            <RowDefinition Height="250"/>
            <!-- Таблица -->
            <RowDefinition Height="Auto"/>
            <!-- Статус бар -->
        </Grid.RowDefinitions>

        <!-- Меню -->
        <Menu Grid.Row="0">
            <MenuItem Header="Файл">
                <MenuItem Header="Экспорт в PNG" Command="{Binding ExportToPngCommand}"/>
                <MenuItem Header="Выход"/>
            </MenuItem>
            <MenuItem Header="Настройки">
                <MenuItem Header="Подключение к БД..." Command="{Binding OpenConnectionSettingsCommand}"/>
            </MenuItem>
            <MenuItem Header="Обновить" Command="{Binding RefreshDataCommand}"/>
            <MenuItem Header="Справка"/>
        </Menu>

        <!-- Фильтры -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="15" Margin="10,5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding FromDate, Mode=TwoWay}" Width="120"/>
                    <TextBlock Text="—" VerticalAlignment="Center" Margin="5,0"/>
                    <DatePicker SelectedDate="{Binding ToDate, Mode=TwoWay}" Width="120"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding Categories}" 
                              SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                              DisplayMemberPath="Name" Width="150"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Регион:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding Regions}" 
                              SelectedItem="{Binding SelectedRegion, Mode=TwoWay}"
                              DisplayMemberPath="Name" Width="150"/>
                </StackPanel>

                <Button Content="Применить" Command="{Binding ApplyFiltersCommand}" Width="100" Margin="0,0,10,0"/>
                <Button Content="Сбросить" Command="{Binding ResetFiltersCommand}" Width="100"/>
            </StackPanel>
        </Border>

        <!-- KPI -->
        <UniformGrid Grid.Row="2" Columns="3" Margin="15,5,15,10">
            <Border Background="#2E7D32" CornerRadius="8" Margin="8" Padding="18">
                <StackPanel>
                    <TextBlock Text="Общая выручка" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding TotalRevenue, StringFormat='N2'}" Foreground="White" FontSize="26" FontWeight="Bold"/>
                    <TextBlock Text="₽" Foreground="#A5D6A7" FontSize="15"/>
                </StackPanel>
            </Border>

            <Border Background="#1565C0" CornerRadius="8" Margin="8" Padding="18">
                <StackPanel>
                    <TextBlock Text="Количество заказов" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding OrderCount}" Foreground="White" FontSize="26" FontWeight="Bold"/>
                    <TextBlock Text="шт." Foreground="#90CAF9" FontSize="15"/>
                </StackPanel>
            </Border>

            <Border Background="#6A1B9A" CornerRadius="8" Margin="8" Padding="18">
                <StackPanel>
                    <TextBlock Text="Средний чек" Foreground="White" FontSize="14"/>
                    <TextBlock Text="{Binding AverageCheck, StringFormat='N2'}" Foreground="White" FontSize="26" FontWeight="Bold"/>
                    <TextBlock Text="₽" Foreground="#CE93D8" FontSize="15"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- График OxyPlot -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
        Margin="15,5,15,10" CornerRadius="6" Padding="15">

            <StackPanel>
                <TextBlock Text="Выручка по категориям (кликни по категории для фильтрации)" 
                   FontSize="16" FontWeight="SemiBold" 
                   Margin="0,0,0,10"/>

                <oxy:PlotView x:Name="CategoryChart" 
                      Model="{Binding CategoryRevenuePlotModel}" 
                      Height="280"
                      MouseDown="CategoryChart_MouseDown"/>
            </StackPanel>
        </Border>

        <!-- Таблица (новая) -->
        <Border Grid.Row="4" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                Margin="15,5,15,10" CornerRadius="6" Padding="10">

            <StackPanel>
                <TextBlock Text="Выручка и заказы по категориям" 
                           FontSize="16" FontWeight="SemiBold" 
                           Margin="0,0,0,10"/>

                <DataGrid ItemsSource="{Binding CategorySummaries}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Height="180"
                          Margin="0,5,0,0"
                          AlternatingRowBackground="#F5F5F5"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Категория" 
                                            Binding="{Binding CategoryName}" 
                                            Width="*"/>
                        <DataGridTextColumn Header="Выручка (₽)" 
                                            Binding="{Binding TotalRevenue, StringFormat='N2'}" 
                                            Width="150"/>
                        <DataGridTextColumn Header="Количество заказов" 
                                            Binding="{Binding OrderCount}" 
                                            Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- Статус бар -->
        <StatusBar Grid.Row="5">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding LastUpdated, StringFormat='Последнее обновление: {0:dd.MM.yyyy HH:mm}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>